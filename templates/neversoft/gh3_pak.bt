BigEndian();

// TODO: Move to common file
typedef struct
{
    uint value<format=hex>;
} Hash<read=Str("%X8", this.value)>;

// 32 bytes
typedef struct
{
    Hash file_extension;
    uint file_offset;
    uint file_size;

    Hash pak_full_file_path;
    Hash pak_file_path;
    Hash file_name_no_extension;
    
    uint unknown;
    uint flags;
} PakFileInfo;

typedef struct
{
    PakFileInfo info;
} PakFile;

PakFile file;